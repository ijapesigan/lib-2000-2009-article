@Article{Thompson-Dizen-Berenbaum-2009,
  author       = {Thompson, Renee J. and Diz{\'e}n, M{\"u}ge and Berenbaum, Howard},
  date         = {2009-10},
  journaltitle = {Journal of Research in Personality},
  title        = {The unique relations between emotional awareness and facets of affective instability},
  doi          = {10.1016/j.jrp.2009.07.006},
  issn         = {0092-6566},
  number       = {5},
  pages        = {875--879},
  volume       = {43},
  abstract     = {The relation between affective instability and two facets of emotional awareness, attention to emotion and clarity of emotion, was examined in two community samples (Ns = 303, 101) and one student sample (N = 409). Affective instability was positively associated with attention to emotion and negatively associated with clarity of emotion. The two facets of affective instability, affect intensity and emotional variability, were differentially associated with the two components of emotional awareness. As hypothesized, affect intensity was uniquely associated with attention to emotion, whereas emotional variability was uniquely (inversely) associated with clarity of emotion even after taking into account shared variance with neuroticism and gender.},
  publisher    = {Elsevier BV},
}
