@Article{Fleeson-2001,
  author = {William Fleeson},
  date = {2001},
  journaltitle = {Journal of Personality and Social Psychology},
  title = {Toward a structure- and process-integrated view of personality: Traits as density distributions of states},
  doi = {10.1037/0022-3514.80.6.1011},
  issn = {0022-3514},
  number = {6},
  pages = {1011--1027},
  volume = {80},
  abstract = {Three experience sampling studies explored the distributions of Big-Five-relevant states (behavior) across 2 to 3 weeks of everyday life. Within-person variability was high, such that the typical individual regularly and routinely manifested nearly all levels of all traits in his or her everyday behavior. Second, individual differences in central tendencies of behavioral distributions were almost perfectly stable. Third, amount of behavioral variability (and skew and kurtosis) were revealed as stable individual differences. Finally, amount of within-person variability in extraversion was shown to reflect individual differences in reactivity to extraversion-relevant situational cues. Thus, decontextualized and noncontigent Big-Five content is highly useful for descriptions of individuals' density distributions as wholes. Simultaneously, contextualized and contingent personality units (e.g., conditional traits, goals) are needed for describing the considerable within-person variation.},
  publisher = {American Psychological Association (APA)},
}
